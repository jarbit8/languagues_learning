{"tipo":"hueco","enunciado":"She ___ Ana.","respuesta":"is","aceptadas":["'s"]},
{"tipo":"hueco","enunciado":"You ___ welcome.","respuesta":"are","aceptadas":["'re"]},
{"tipo":"hueco","enunciado":"We ___ students.","respuesta":"are","aceptadas":["'re"]},
{"tipo":"opcion_multiple","enunciado":"He ___ fine.","opciones":["is","am","are","be"],"respuesta":"is"},
{"tipo":"opcion_multiple","enunciado":"They ___ students.","opciones":["is","am","are"],"respuesta":"are"},
{"tipo":"opcion_multiple","enunciado":"¿Cuál es la contracción de 'I am'?","opciones":["I'm","I're","I's"],"respuesta":"I'm"},
{"tipo":"ordenar","enunciado":"Ordena: ¿cómo estás?","opciones":["how","are","you"],"respuesta":"how are you"},
{"tipo":"ordenar","enunciado":"Ordena: yo soy Joel.","opciones":["I","am","Joel"],"respuesta":"I am Joel"},
{"tipo":"ordenar","enunciado":"Ordena: mucho gusto.","opciones":["nice","to","meet","you"],"respuesta":"nice to meet you"},

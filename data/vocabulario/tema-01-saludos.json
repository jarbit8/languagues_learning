{ "tema": 1, "titulo": "Saludos y presentaciones", "conceptos": [
{"id":"a1-t01-001","es":"hola","en":{"texto":"hello","ejemplo":"Hello! How are you?","pron":"je-LOU"},"fr":{"texto":"bonjour","ejemplo":"Bonjour ! Comment ça va ?","pron":"bon-YUR"},"nota":"FR: bonjour sirve todo el día; de noche bonsoir."},
{"id":"a1-t01-002","es":"hola (informal)","en":{"texto":"hi","ejemplo":"Hi! I'm Jarbit.","pron":"JAI"},"fr":{"texto":"salut","ejemplo":"Salut ! Je m'appelle Jarbit.","pron":"sa-LU"},"nota":"FR: salut sirve para hola Y chau."},
{"id":"a1-t01-003","es":"buenos días","en":{"texto":"good morning","ejemplo":"Good morning, Mr Lee!","pron":"gud MOR-ning"},"fr":{"texto":"bonjour","ejemplo":"Bonjour, monsieur !","pron":"bon-YUR"},"nota":"EN: good morning hasta el mediodía."},
{"id":"a1-t01-004","es":"buenas tardes","en":{"texto":"good afternoon","ejemplo":"Good afternoon, Ana!","pron":"gud af-ter-NUN"},"fr":{"texto":"bon après-midi","ejemplo":"Bon après-midi !","pron":"bon a-pre-mi-DI"},"nota":"FR: para saludar de tarde también se usa bonjour."},
{"id":"a1-t01-005","es":"buenas noches (al llegar)","en":{"texto":"good evening","ejemplo":"Good evening, madam.","pron":"gud IV-ning"},"fr":{"texto":"bonsoir","ejemplo":"Bonsoir !","pron":"bon-SUAR"}},
{"id":"a1-t01-006","es":"buenas noches (al dormir)","en":{"texto":"good night","ejemplo":"Good night!","pron":"gud NAIT"},"fr":{"texto":"bonne nuit","ejemplo":"Bonne nuit !","pron":"bon NUI"},"nota":"Solo al ir a dormir, no para saludar."},
{"id":"a1-t01-007","es":"adiós","en":{"texto":"goodbye","ejemplo":"Goodbye, teacher!","pron":"gud-BAI"},"fr":{"texto":"au revoir","ejemplo":"Au revoir, madame !","pron":"o re-VUAR"}},
{"id":"a1-t01-008","es":"chau (informal)","en":{"texto":"bye","ejemplo":"Bye! See you later.","pron":"BAI"},"fr":{"texto":"salut","ejemplo":"Salut ! À plus tard.","pron":"sa-LU"},"nota":"FR: salut también significa 'hola'."},
{"id":"a1-t01-009","es":"hasta luego","en":{"texto":"see you later","ejemplo":"See you later, Ana!","pron":"si yu LEI-ter"},"fr":{"texto":"à plus tard","ejemplo":"À plus tard !","pron":"a plu TAR"}},
{"id":"a1-t01-010","es":"hasta pronto","en":{"texto":"see you soon","ejemplo":"See you soon!","pron":"si yu SUN"},"fr":{"texto":"à bientôt","ejemplo":"À bientôt !","pron":"a byen-TO"}},
{"id":"a1-t01-011","es":"hasta mañana","en":{"texto":"see you tomorrow","ejemplo":"See you tomorrow!","pron":"si yu tu-MO-rou"},"fr":{"texto":"à demain","ejemplo":"À demain !","pron":"a de-MEN"}},
{"id":"a1-t01-012","es":"por favor","en":{"texto":"please","ejemplo":"A coffee, please.","pron":"PLIS"},"fr":{"texto":"s'il vous plaît","ejemplo":"Un café, s'il vous plaît.","pron":"sil vu PLE"},"nota":"FR: con amigos y familia se dice 's'il te plaît' en vez de s'il vous plaît."},
{"id":"a1-t01-013","es":"gracias","en":{"texto":"thank you","ejemplo":"Thank you, Maria!","pron":"ZANK-yu"},"fr":{"texto":"merci","ejemplo":"Merci, Maria !","pron":"mer-SI"}},
{"id":"a1-t01-014","es":"de nada","en":{"texto":"you're welcome","ejemplo":"You're welcome!","pron":"yor UEL-kem"},"fr":{"texto":"de rien","ejemplo":"De rien !","pron":"de RYEN"}},
{"id":"a1-t01-015","es":"perdón","en":{"texto":"sorry","ejemplo":"Sorry!","pron":"SO-ri"},"fr":{"texto":"pardon","ejemplo":"Pardon !","pron":"par-DON"},"nota":"Para disculparte por algo."},
{"id":"a1-t01-016","es":"disculpe","en":{"texto":"excuse me","ejemplo":"Excuse me, sir.","pron":"eks-KIUS mi"},"fr":{"texto":"excusez-moi","ejemplo":"Excusez-moi, monsieur.","pron":"eks-ku-se-MUA"},"nota":"Para llamar la atención o pasar."},
{"id":"a1-t01-017","es":"no hay problema","en":{"texto":"no problem","ejemplo":"No problem!","pron":"nou PRO-blem"},"fr":{"texto":"pas de problème","ejemplo":"Pas de problème !","pron":"pa de pro-BLEM"}},
{"id":"a1-t01-018","es":"sí","en":{"texto":"yes","ejemplo":"Yes, I'm a student.","pron":"YES"},"fr":{"texto":"oui","ejemplo":"Oui, je suis étudiant.","pron":"UI"}},
{"id":"a1-t01-019","es":"no","en":{"texto":"no","ejemplo":"No, thank you.","pron":"NOU"},"fr":{"texto":"non","ejemplo":"Non, merci.","pron":"NON"}},
{"id":"a1-t01-020","es":"señor","en":{"texto":"Mr","ejemplo":"Mr Smith is a teacher.","pron":"MIS-ter"},"fr":{"texto":"monsieur","ejemplo":"Bonjour, monsieur !","pron":"me-SYE"}},
{"id":"a1-t01-021","es":"señora","en":{"texto":"Mrs","ejemplo":"Mrs Lee is here.","pron":"MI-sis"},"fr":{"texto":"madame","ejemplo":"Bonjour, madame !","pron":"ma-DAM"}},
{"id":"a1-t01-022","es":"señorita","en":{"texto":"Miss","ejemplo":"Welcome, Miss Ana!","pron":"MIS"},"fr":{"texto":"mademoiselle","ejemplo":"Bonjour, mademoiselle !","pron":"mad-mua-SEL"}},

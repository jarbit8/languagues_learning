{ "titulo": "Recommander des endroits",
"lineas": [
{"hablante":"A","texto":"Il y a un bon musée dans cette ville ?"},
{"hablante":"B","texto":"Oui, il y a un excellent musée près du parc."},
{"hablante":"A","texto":"On peut y aller à pied ?"},
{"hablante":"B","texto":"Oui, c'est près, on peut marcher."},
{"hablante":"A","texto":"Il est ouvert le dimanche ?"},
{"hablante":"B","texto":"Non, il est fermé le dimanche."},
{"hablante":"A","texto":"Et un bon restaurant ?"},
{"hablante":"B","texto":"Il y en a un sympa à côté de la bibliothèque."}
],
"preguntas": [
